APP_PORT=4173
HOST_PORT=4173
GHCR_IMAGE=ghcr.io/githubphadnis/golfmeadows_web:latest
GOLFMEADOWS_DATA_DIR=/opt/golfmeadows/data
TZ=Asia/Kolkata
GOLFMEADOWS_ADMIN_TOKEN=change-me-to-a-long-random-secret
# Comma-separated list of allowed browser origins (exact URLs or wildcard subdomains).
# Examples:
#   https://golfmeadows.org
#   https://admin.golfmeadows.org
#   https://*.golfmeadows.org
GOLFMEADOWS_CORS_ORIGINS=https://golfmeadows.org,https://admin.golfmeadows.org
# Optional Google admin auth. When enabled, admin UI can use Google ID tokens.
GOLFMEADOWS_GOOGLE_CLIENT_ID=
GOLFMEADOWS_ADMIN_GOOGLE_EMAILS=admin@golfmeadows.org,ops@golfmeadows.org
# Secret for hidden admin-user CSV sync endpoint.
# Required only if you plan to use POST /api/v1/admin/users-sync.csv
GOLFMEADOWS_USERS_CSV_SECRET=replace-with-very-long-random-secret
